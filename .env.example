APP_NAME="BBM - Belajar Bahasa Madura"
APP_ENV=local
APP_KEY=base64:CbItNIZHNeQOhalzjF2pEXP0K6JURyiXAo4GTxpoTD0=
APP_DEBUG=true
APP_URL=http://localhost:8005
FRONTEND_URL=http://localhost:3045
API_VERSION=2.0.0
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration BBM V2
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bbm_v2
DB_USERNAME=root
DB_PASSWORD=

# Koneksi Legacy (File SQL Lama)
DB_LEGACY_CONNECTION=mysql_legacy
DB_LEGACY_HOST=127.0.0.1
DB_LEGACY_PORT=3306
DB_LEGACY_DATABASE=bbm_legacy
DB_LEGACY_USERNAME=root
DB_LEGACY_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=localhost:3045
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null #sementara null, nanti sesuai domain cth: .example.com
SESSION_SECURE_COOKIE=false #sementara false, nanti true jika sudah menggunakan HTTPS
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
